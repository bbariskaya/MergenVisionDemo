# PostgreSQL
POSTGRES_USER=mergenvision
POSTGRES_PASSWORD=change-me-in-env
POSTGRES_DB=mergenvision
DATABASE_URL=postgresql+psycopg://mergenvision:change-me-in-env@postgres:5432/mergenvision

# MinIO
MINIO_ROOT_USER=mergenvision
MINIO_ROOT_PASSWORD=change-me-in-env
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=mergenvision
MINIO_SECRET_KEY=change-me-in-env
MINIO_BUCKET_PHOTOS=mergenvision-photos

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=face_samples

# Security
HMAC_KEY=change-me-in-env-32-bytes-min

# ML
MODEL_PACK=antelopev2
EMBEDDING_MODEL_VERSION=antelopev2
PIPELINE_COMPATIBILITY_VERSION=v1
INFERENCE_BACKEND=tensorrt
BULK_WORKERS=gpu-worker-1,gpu-worker-2
DETECTOR_MODEL_PATH=/models/detector.onnx
EMBEDDER_MODEL_PATH=/models/recognizer.onnx
DETECTOR_INPUT_SIZE=640
EMBEDDER_INPUT_SIZE=112
EMBEDDING_DIM=512
DETECTOR_CONFIDENCE_THRESHOLD=0.5
DETECTOR_NMS_IOU=0.4
MATCHED_THRESHOLD=0.6
POSSIBLE_THRESHOLD=0.4
TOP_K_DEFAULT=5
TOP_K_MAX=20

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
